[*.cs]

# CA2007: Consider calling ConfigureAwait on the awaited task
dotnet_diagnostic.CA2007.severity = none

# CA1031: Modify code to catch a more specific allowed exception type, or rethrow the exception
dotnet_diagnostic.CA1031.severity = suggestion

# CA1062: In externally visible method, validate parameter is non-null before using it. If appropriate, throw an ArgumentNullException when the argument is null or add a Code Contract precondition asserting non-null argument.
dotnet_diagnostic.CA1062.severity = none

# CA1515: Consider making public types internal
dotnet_diagnostic.CA1515.severity = none

# CA1859: Use concrete types when possible for improved performance
dotnet_diagnostic.CA1859.severity = none

# CA1860: Avoid using 'Enumerable.Any()' extension method
dotnet_diagnostic.CA1860.severity = none

# CA1863: Use 'CompositeFormat'
dotnet_diagnostic.CA1863.severity = none


# IDE0160: Convert to block scoped namespace
csharp_style_namespace_declarations = file_scoped


### Coding styles

tab_width = 4
indent_size = 4
end_of_line = crlf
indent_style = space

# IDE0160: Convert to block scoped namespace
csharp_style_namespace_declarations = file_scoped

# IDE0200: Remove unnecessary lambda expression - see: https://github.com/dotnet/roslyn/issues/77395
dotnet_diagnostic.IDE0200.severity = none


[*.{xml,csproj,props,targets,config,resx,ruleset}]

tab_width = 2
indent_size = 2
end_of_line = crlf
indent_style = space